{
    "version" : 1,
    "disable_existing_loggers": false,
    "formatters":{
        "access":{
            "()": "uvicorn.logging.AccessFormatter",
            "fmt": "%(asctime)s | %(levelname)s | %(name)s | %(client_addr)s | \"%(request_line)s\" %(status_code)s",
            "datefmt" : "%a %S:%M:%H  %d-%m-%Y",
            "use_colors" : true
        },
        "standard": {
            "format" :"%(asctime)s | %(levelname)s | %(name)s | %(message)s",
            "datefmt":"%a %S:%M:%H  %d-%m-%Y"
        } },
    "handlers" : {
        "terminal" : {
            "class" :"logging.StreamHandler",
            "level" : "DEBUG",
            "formatter" : "standard",
            "stream": "ext://sys.stdout"
        },
        "terminal_access":{
            "class" : "logging.StreamHandler",
            "level" : "INFO",
            "formatter": "access",
            "stream" : "ext://sys.stdout"
        }
             
        },
    "loggers":{
        "app":{
            "level" : "INFO",
            "handlers" : ["terminal"],
            "propagate": false
        },
    "sqlalchemy.engine":{
        "level": "WARNING",
        "handlers" : ["terminal"],
        "propagate": false
    },
    "sqlalchemy.pool" : {
        "level" : "WARNING",
        "handlers" : ["terminal"],
        "propagate":false
    },
    "uvicorn":{
        "level" : "INFO",
        "handlers": ["terminal"],
        "propagate": false
    },
    "uvicorn.error":{
        "level": "INFO",
        "handlers": ["terminal"],
        "propagate": false
    },
    "uvicorn.access": {
        "level" : "INFO",
        "handlers": ["terminal_access"],
        "propagate": false
    },
    "root":{
        "level" :"WARNING", 
        "handlers" : ["terminal"]
       
    }
    }
    }
